generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  runtime  = "nodejs"
}

datasource db {
  provider = "postgresql"
}

model DemoSearch {
  id        String   @id @default(cuid())
  custId    String
  label     String?
  createdAt DateTime @default(now())

  @@index([custId])
}
